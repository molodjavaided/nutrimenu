generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum VenueStatus {
  PENDING
  APPROVED
  REJECTED
}

enum UserRole {
  OWNER
  ADMIN
}

enum Plan {
  TEST
  START
  STANDARD
  CUSTOM
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  passwordHash        String
  role                UserRole             @default(OWNER)
  plan                Plan                 @default(START)
  trialEndsAt         DateTime?
  paidUntil           DateTime?
  emailVerified       Boolean              @default(false)
  ttkImportCount      Int                  @default(0)
  ttkImportMonth      Int?
  aiEnrichCount       Int                  @default(0)
  aiEnrichMonth       Int?
  bonusItems          Int                  @default(0)
  bonusAiImports      Int                  @default(0)
  bonusAiEnriches     Int                  @default(0)
  bonusTtkExports     Int                  @default(0)
  onboardingStep      Int                  @default(0)
  onboardingCompletedAt DateTime?
  onboardingDismissedAt DateTime?
  telegramChatId      String?              @unique
  telegramUsername    String?
  createdAt           DateTime             @default(now())
  venue               Venue?
  passwordResetTokens PasswordResetToken[]
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
}

model Venue {
  id             String      @id @default(cuid())
  slug           String      @unique
  name           String
  country        String?
  city           String?
  address        String?
  description    String?
  workingHours   String?
  logo           String?
  tags           String[]    @default([])
  status         VenueStatus @default(PENDING)
  allowAdminEdit Boolean     @default(false)
  adminNote      String?
  briefingState  Json?
  briefingCompletedAt DateTime?
  ownerId        String      @unique
  owner          User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  categories  Category[]
  menuItems   MenuItem[]
  ingredients IngredientRef[]
  files       VenueFile[]
}

model VenueFile {
  id           String   @id @default(cuid())
  venueId      String
  venue        Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  uploadedById String
  uploaderRole UserRole
  category     String   // 'menu_source' | 'ttk' | 'logo' | 'photo' | 'other'
  filename     String
  url          String
  size         Int
  mimeType     String
  notes        String?
  createdAt    DateTime @default(now())

  @@index([venueId, createdAt])
}

model Category {
  id        String     @id @default(cuid())
  venueId   String
  venue     Venue      @relation(fields: [venueId], references: [id], onDelete: Cascade)
  name      String
  sortOrder Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  items     MenuItem[]

  @@index([venueId, sortOrder])
}

model MenuItem {
  id             String   @id @default(cuid())
  categoryId     String
  category       Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  venueId        String
  venue          Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  photo          String?
  price          Float?
  weight         Float    @default(0)
  weightUnit     String   @default("г")
  calories       Float    @default(0)
  protein        Float    @default(0)
  fat            Float    @default(0)
  carbs          Float    @default(0)
  isAvailable    Boolean  @default(true)
  sizes          Json?
  composition    Json?
  variantGroups  Json?
  modifierGroups Json?
  creationMode   String?
  finalWeight    Float?
  servingSize    Float?
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([categoryId, sortOrder])
  @@index([venueId])
}

enum FeedbackSource {
  OWNER
  GUEST
}

enum FeedbackCategory {
  bug
  idea
  question
  billing
  other
}

enum FeedbackStatus {
  new
  triaged
  resolved
  wontfix
}

model Feedback {
  id          String           @id @default(cuid())
  createdAt   DateTime         @default(now())
  source      FeedbackSource
  category    FeedbackCategory @default(other)
  message     String
  rating      Int?
  email       String?
  pageUrl     String?
  userAgent   String?
  venueId     String?
  userId      String?
  status      FeedbackStatus   @default(new)
  note        String?
  lastReplyAt DateTime?
  ownerUnread Boolean          @default(false)
  adminUnread Boolean          @default(true)
  replies     FeedbackReply[]

  @@index([status, createdAt])
  @@index([source, createdAt])
  @@index([venueId])
  @@index([userId])
}

model FeedbackReply {
  id         String   @id @default(cuid())
  feedbackId String
  feedback   Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  authorRole UserRole
  authorId   String
  message    String
  createdAt  DateTime @default(now())

  @@index([feedbackId, createdAt])
}

model MenuView {
  id      String   @id @default(cuid())
  venueId String
  date    DateTime @default(now()) @db.Date
  count   Int      @default(1)

  @@unique([venueId, date])
  @@index([venueId])
}

model BarcodeCache {
  barcode      String   @id
  name         String?
  brand        String?
  manufacturer String?
  category     String?
  packageSize  String?
  calories     Float?
  protein      Float?
  fat          Float?
  carbs        Float?
  ingredients  String?
  confidence   String   @default("medium") // low / medium / high
  source       String   @default("gemini") // gemini / perplexity / manual
  found        Boolean  @default(true)
  fetchedAt    DateTime @default(now())

  @@index([fetchedAt])
}

model IngredientRef {
  id             String  @id @default(cuid())
  venueId        String?
  venue          Venue?  @relation(fields: [venueId], references: [id], onDelete: Cascade)
  name           String
  unit           String  @default("г")
  weightPerUnit  Float?
  caloriesPer100 Float   @default(0)
  proteinPer100  Float   @default(0)
  fatPer100      Float   @default(0)
  carbsPer100    Float   @default(0)
  category       String?
  isSystem       Boolean @default(false)
  type           String  @default("mono")
  composition    Json?
  compositionText String?
  instructions   String?
  barcode        String?
  manufacturer   String?
  packageSize    String?
  yieldCoefficients Json?
  coldLossPercent   Float?
  pricePerKg        Float?

  @@unique([venueId, barcode])
  @@index([venueId])
  @@index([isSystem])
  @@index([barcode])
}
